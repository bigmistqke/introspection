{
  "name": "@introspection/serve",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./dist/node.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/node.ts src/client.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@introspection/types": "workspace:*",
    "@introspection/read": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}