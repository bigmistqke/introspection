{
  "name": "introspection-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "demos:static-report": "pnpm --filter @introspection/demo-static-report run generate",
    "demos:vanilla-basic": "pnpm --filter @introspection/demo-vanilla-basic dev",
    "demos:solid-streaming": "pnpm --filter @introspection/demo-solid-streaming dev",
    "demos:solid-streaming:test": "pnpm --filter @introspection/demo-solid-streaming test",
    "demos:wc-graph": "pnpm --filter @introspection/demo-wc-graph dev",
    "demos:react-session-list": "pnpm --filter @introspection/demo-react-session-list dev"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "tsup": "^8.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
